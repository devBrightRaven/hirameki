{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-start-catchup.mjs",
          "timeout": 5
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/session-end-check.mjs"
        },
        {
          "type": "command",
          "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/extract-actions.mjs"
        }
      ]
    }
  ]
}
